# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install ALL dependencies (including devDependencies for build)
RUN npm ci && \
    npm cache clean --force

# Copy source code
COPY . .

# Build the pharmacist application with production env vars
ARG VITE_API_URL=https://api.spravka.novamedika.com
ARG VITE_WS_URL=wss://api.spravka.novamedika.com/api/pharmacist/ws/pharmacist

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_WS_URL=$VITE_WS_URL

RUN npm run build:pharmacist

# Production stage
FROM nginx:alpine AS prod

# Copy built assets from builder (pharmacist-specific dist)
COPY --from=builder /app/dist-pharmacist /usr/share/nginx/html

# Copy custom nginx configuration
COPY nginx-pharmacist.conf /etc/nginx/conf.d/default.conf

# Add healthcheck script
RUN apk add --no-cache curl

# Expose port
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD wget -q --spider http://localhost:80 || exit 1

CMD ["nginx", "-g", "daemon off;"]
