# ============================================
# NovaMedika2 - Environment Configuration
# ============================================
# Скопируйте этот файл в .env и заполните значения

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=novamedika
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=novamedika_prod
DATABASE_URL=postgresql+asyncpg://novamedika:your_secure_password_here@postgres:5432/novamedika_prod

# ============================================
# Application Security
# ============================================
SECRET_KEY=your_super_secret_key_min_32_chars_change_in_production
CORS_ORIGINS=https://spravka.novamedika.com,https://www.spravka.novamedika.com

# ============================================
# Encryption Key (ОАЦ Compliance)
# ============================================
# Ключ для шифрования персональных данных (telegram_id, phone)
# Генерация: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ВАЖНО: Используйте один и тот же ключ для всех сервисов!
ENCRYPTION_KEY=your_encryption_key_here_generate_with_python_command_above

# ============================================
# Telegram Bot
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather

# ============================================
# Redis
# ============================================
REDIS_PASSWORD=your_redis_password_here
# REDIS_URL — приоритетный способ подключения. Если не задан, будет построен из REDIS_HOST/PORT/DB/PASSWORD
# REDIS_URL=redis://:your_redis_password_here@redis:6379/1
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1

# ============================================
# Frontend
# ============================================
VITE_API_URL=https://api.spravka.novamedika.com
VITE_API_KEY=your_api_key_for_anonymous_access
VITE_WS_URL=wss://api.spravka.novamedika.com/api/pharmacist/ws/pharmacist
VITE_WS_URL_PHARMACIST=wss://api.spravka.novamedika.com/api/pharmacist/ws/pharmacist

# ============================================
# Domain Configuration
# ============================================
DOMAIN=spravka.novamedika.com
PHARMACIST_DASHBOARD_URL=https://spravka.novamedika.com/pharmacist

# ============================================
# OpenVAS Vulnerability Scanner (ОАЦ Compliance)
# ============================================
# Пароль для веб-интерфейса Greenbone Security Assistant (GSA)
# Доступ: http://<server-ip>:9392 или https://<server-ip>
# Username: admin
OPENVAS_PASSWORD=your_secure_openvas_password_min_12_chars

# ============================================
# Additional Settings
# ============================================

ENVIRONMENT=production
FRONTEND_URL=https://spravka.novamedika.com
