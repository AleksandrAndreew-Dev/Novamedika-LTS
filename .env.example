# ===========================================
# Novamedika2 — Environment Variables
# ===========================================
# Скопируй в .env и заполни значения
# НЕ коммить .env в git!

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/novamedika_prod
ASYNCPG_DATABASE_URL=postgresql://user:password@postgres:5432/novamedika_prod
POSTGRES_USER=novamedika
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=novamedika_prod

# --- Backend ---
SECRET_KEY=CHANGE_ME_at_least_32_characters_long_secret_key_for_jwt
ENVIRONMENT=production
CORS_ORIGINS=https://spravka.novamedika.com,http://localhost:3000

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=123456789:CHANGE_ME_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://api.spravka.novamedika.com/webhook/
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_webhook_secret_token

# --- Admin Auth (для /clear-all-data, /load-pharmacies и т.д.) ---
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# --- Booking & Questions API Key ---
BOOKING_API_KEYS=change_me_api_key_1,change_me_api_key_2

# --- Upload Auth (HTTP Basic для CSV upload) ---
CORRECT_USERNAME=upload_user
CORRECT_PASSWORD=CHANGE_ME_upload_password

# --- Registration Secret (для регистрации фармацевтов) ---
REGISTRATION_SECRET_WORD=CHANGE_ME_unique_secret_word

# --- Redis ---
REDIS_PASSWORD=mySuperPassword198923213!ersfd-sda
REDIS_HOST=redis

# --- Telegram Admin (для /qa/drop, /qa/stats) ---
ADMIN_API_KEYS=change_me_telegram_admin_api_key

# --- Encryption (для pharmacy_api_configs auth_token) ---
ENCRYPTION_KEY=CHANGE_ME_32_bytes_base64_fernet_key

# --- Frontend ---
VITE_API_URL=https://api.spravka.novamedika.com
DOMAIN=spravka.novamedika.com
SSL_EMAIL=admin@novamedika.com

# --- Traefik Dashboard Auth ---
TRAEFIK_AUTH_USERS=admin:CHANGE_ME_htpasswd_hash

# --- A1 SMS API (optional) ---
a1User=CHANGE_ME_a1_sms_user
a1apk=CHANGE_ME_a1_sms_api_key
